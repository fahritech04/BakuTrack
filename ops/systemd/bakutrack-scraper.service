[Unit]
Description=BakuTrack Python Scraper API
After=network.target

[Service]
User=www-data
Group=www-data
Restart=always
RestartSec=5
WorkingDirectory=/var/www/bakutrack/scraper
EnvironmentFile=/var/www/bakutrack/scraper/.env
ExecStart=/var/www/bakutrack/scraper/.venv/bin/uvicorn src.main:app --host 0.0.0.0 --port 9000

[Install]
WantedBy=multi-user.target
